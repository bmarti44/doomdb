{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:doomdb:t12.1:database-collector-output",
  "title": "Redacted T12.1 database collector output",
  "type": "object",
  "additionalProperties": false,
  "required": ["families", "plans", "vsql", "shapes", "stageSamples"],
  "properties": {
    "families": {"const": ["step", "frame", "asset"]},
    "plans": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/plan"}},
    "vsql": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/cursor"}},
    "shapes": {"type": "array", "minItems": 60, "maxItems": 60, "items": {"$ref": "#/$defs/shape"}},
    "stageSamples": {"type": "array", "minItems": 300, "maxItems": 300, "items": {"$ref": "#/$defs/stage"}}
  },
  "$defs": {
    "family": {"enum": ["step", "frame", "asset"]},
    "nonnegative": {"type": "number", "minimum": 0},
    "plan": {
      "type": "object",
      "required": ["family", "format", "planHashValue", "executionsBefore", "executionsAfter", "operations"],
      "properties": {
        "family": {"$ref": "#/$defs/family"}, "format": {"const": "ALLSTATS LAST"},
        "planHashValue": {"type": "integer"}, "executionsBefore": {"type": "integer", "minimum": 0},
        "executionsAfter": {"type": "integer", "minimum": 1},
        "operations": {"type": "array", "minItems": 1}
      }
    },
    "cursor": {
      "type": "object",
      "required": ["family", "sqlIdSha256", "forceMatchingSignature", "normalizedShape", "parseCallsBefore", "parseCallsAfter", "executionsBefore", "executionsAfter", "versionCount"],
      "properties": {
        "family": {"$ref": "#/$defs/family"},
        "sqlIdSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "forceMatchingSignature": {"type": "string", "pattern": "^[0-9]+$"},
        "normalizedShape": {"type": "string"},
        "parseCallsBefore": {"type": "integer", "minimum": 0}, "parseCallsAfter": {"type": "integer", "minimum": 0},
        "executionsBefore": {"type": "integer", "minimum": 0}, "executionsAfter": {"type": "integer", "minimum": 0},
        "versionCount": {"const": 1}
      }
    },
    "shape": {
      "type": "object",
      "required": ["family", "pose", "command", "normalizedShape", "forceMatchingSignature", "bindCount"],
      "properties": {
        "family": {"$ref": "#/$defs/family"}, "pose": {"enum": ["spawn", "corridor", "door", "combat"]},
        "command": {"enum": ["IDLE", "MOVE", "TURN", "USE", "FIRE"]},
        "normalizedShape": {"type": "string"}, "forceMatchingSignature": {"type": "string", "pattern": "^[0-9]+$"},
        "bindCount": {"type": "integer", "minimum": 1}
      }
    },
    "stage": {
      "type": "object",
      "required": ["frame", "databaseMs", "ordsMs", "prepareMs", "tickerMs", "renderMs", "codecMs", "blobMs", "finalizeMs", "commitMs", "r1Ms", "r2Ms"],
      "properties": {
        "frame": {"type": "integer", "minimum": 0, "maximum": 299},
        "databaseMs": {"$ref": "#/$defs/nonnegative"}, "ordsMs": {"$ref": "#/$defs/nonnegative"},
        "prepareMs": {"$ref": "#/$defs/nonnegative"}, "tickerMs": {"$ref": "#/$defs/nonnegative"},
        "renderMs": {"$ref": "#/$defs/nonnegative"}, "codecMs": {"$ref": "#/$defs/nonnegative"},
        "blobMs": {"$ref": "#/$defs/nonnegative"}, "finalizeMs": {"$ref": "#/$defs/nonnegative"},
        "commitMs": {"$ref": "#/$defs/nonnegative"},
        "r1Ms": {"$ref": "#/$defs/nonnegative"}, "r2Ms": {"$ref": "#/$defs/nonnegative"}
      }
    }
  }
}
