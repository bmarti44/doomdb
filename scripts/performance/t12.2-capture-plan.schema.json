{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doomdb.invalid/schema/t12.2-capture-plan.schema.json",
  "title": "DoomDB T12.2 live optimization capture plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "task", "synthetic", "resolution", "replay", "capture", "baseline", "attempts", "finalVerification"],
  "properties": {
    "schema": {"const": 1},
    "task": {"const": "T12.2"},
    "synthetic": {"const": false},
    "resolution": {"const": [320, 200]},
    "replay": {"$ref": "#/$defs/replay"},
    "capture": {"$ref": "#/$defs/capture"},
    "baseline": {
      "type": "object", "additionalProperties": false,
      "required": ["evidencePath", "samplesPath", "pinnedManifestSha256", "selectedRevisionSha256"],
      "properties": {"evidencePath": {"$ref": "#/$defs/path"}, "samplesPath": {"$ref": "#/$defs/path"}, "pinnedManifestSha256": {"$ref": "#/$defs/sha"}, "selectedRevisionSha256": {"$ref": "#/$defs/sha"}}
    },
    "attempts": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/attempt"}},
    "finalVerification": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/final"}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "path": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"},
    "replay": {"const": {"frames": 300, "warmFrames": 30, "measuredFrames": 270, "sha256": "1ad47bc8e2a5b7518d68b937a333492d66d7d539f827980086d4b4fdad327fe3"}},
    "capture": {
      "type": "object", "additionalProperties": false, "required": ["owner", "clock", "startedUtc", "endedUtc"],
      "properties": {"owner": {"const": "independent evaluator"}, "clock": {"const": "external monotonic"}, "startedUtc": {"type": "string", "format": "date-time"}, "endedUtc": {"type": "string", "format": "date-time"}}
    },
    "review": {
      "type": "object", "additionalProperties": false,
      "required": ["approved", "targetedMeasuredBottleneck", "ineffectiveWorkChosenToStop", "reviewedUtc", "rationale"],
      "properties": {"approved": {"const": true}, "targetedMeasuredBottleneck": {"const": true}, "ineffectiveWorkChosenToStop": {"const": false}, "reviewedUtc": {"type": "string", "format": "date-time"}, "rationale": {"type": "string", "minLength": 81}}
    },
    "attempt": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "startedUtc", "endedUtc", "changeClass", "changeFingerprint", "sourceAfterSha256", "targetBottleneck", "humanReview", "samplesPath", "diffPath", "correctnessPath", "mutationsPath"],
      "properties": {"id": {"type": "integer", "minimum": 1}, "startedUtc": {"type": "string", "format": "date-time"}, "endedUtc": {"type": "string", "format": "date-time"}, "changeClass": {"enum": ["index", "join-order", "precomputed-static-relation", "partitioning", "aggregation-shape", "codec", "transport", "client"]}, "changeFingerprint": {"type": "string", "minLength": 9}, "sourceAfterSha256": {"$ref": "#/$defs/sha"}, "targetBottleneck": {"enum": ["database", "ords", "payload", "decode-blit", "r1", "r2"]}, "humanReview": {"$ref": "#/$defs/review"}, "samplesPath": {"$ref": "#/$defs/path"}, "diffPath": {"$ref": "#/$defs/path"}, "correctnessPath": {"$ref": "#/$defs/path"}, "mutationsPath": {"$ref": "#/$defs/path"}}
    },
    "final": {"type": "object", "additionalProperties": false, "required": ["environment", "samplesPath"], "properties": {"environment": {"enum": ["local", "cloud"]}, "samplesPath": {"$ref": "#/$defs/path"}}}
  }
}
