@@ -350,5 +354,24 @@ public abstract class AbstractDoomAudio implements IDoomSound {
 	} 
 
+	/** Read-only per-listener parameters for DoomDB's immutable POV payloads. */
+	public int[] doomdbSpatialParams(mobj_t listener, ISoundOrigin source,
+			int volume, int pitch) {
+		vps_t params = new vps_t();
+		params.volume = volume;
+		params.pitch = pitch;
+		params.sep = NORM_SEP;
+		if (source != null && listener != source) {
+			if (!AdjustSoundParams(listener, source, params)) return null;
+			if (source.getX() == listener.x && source.getY() == listener.y) {
+				params.sep = NORM_SEP;
+			}
+		}
+		return new int[] {
+			Math.max(0, Math.min(255, params.volume)),
+			Math.max(0, Math.min(255, params.sep))
+		};
+	}
