+    /** Correctly rounded binary32 square root with no host sqrt dependency. */
+    private static float doomdbSqrtFloat(final float value) {
+        if (value < 0.0f || Float.isNaN(value)) return Float.NaN;
+        if (value == 0.0f || value == Float.POSITIVE_INFINITY) return value;
+        int lower = 0;
+        int upper = 0x7f7fffff;
+        while (lower + 1 < upper) {
+            final int middle = lower + ((upper - lower) >>> 1);
+            final float candidate = Float.intBitsToFloat(middle);
+            if ((double) candidate * candidate <= (double) value) lower = middle;
+            else upper = middle;
+        }
+        final float low = Float.intBitsToFloat(lower);
+        final float high = Float.intBitsToFloat(upper);
+        final double midpoint = ((double) low + (double) high) * 0.5;
+        final double boundary = midpoint * midpoint;
+        if ((double) value > boundary
+                || ((double) value == boundary && (upper & 1) == 0)) return high;
+        return low;
+    }
+
+    /** Exact truncating fixed-point result used by the original offset path. */
+    private static int doomdbScaledSqrt(final float value) {
+        if (!(value > 0.0f)) return 0;
+        final double target = (double) value * 4294967296.0;
+        final long maximum = Integer.MAX_VALUE;
+        if (target >= (double) maximum * maximum) return Integer.MAX_VALUE;
+        long lower = 0;
+        long upper = maximum;
+        while (lower + 1 < upper) {
+            final long middle = lower + ((upper - lower) >>> 1);
+            if ((double) (middle * middle) <= target) lower = middle;
+            else upper = middle;
+        }
+        return (int) lower;
+    }
