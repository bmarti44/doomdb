+/** Install one strict, versioned, big-endian canonical table pack. */
+public static void installCanonicalTablePack(byte[] pack) {
+    if (pack == null || pack.length != CANONICAL_TABLE_PACK_BYTES) {
+        throw new IllegalArgumentException("canonical table pack length");
+    }
+    if (pack[0] != 'D' || pack[1] != 'M' || pack[2] != 'L'
+        || pack[3] != 'U' || pack[4] != 'T' || pack[5] != '0'
+        || pack[6] != '0' || pack[7] != '2') {
+        throw new IllegalArgumentException("canonical table pack magic");
+    }
+    if (readCanonicalInt(pack, 8) != CANONICAL_TABLE_PACK_VERSION
+        || readCanonicalInt(pack, 12) != CANONICAL_TABLE_PACK_ENDIAN
+        || readCanonicalInt(pack, 16) != CANONICAL_TABLE_PACK_HEADER_BYTES
+        || readCanonicalInt(pack, 20) != CANONICAL_TABLE_PACK_BYTES
+        || readCanonicalInt(pack, 24) != finetangent.length
+        || readCanonicalInt(pack, 28) != finesine.length
+        || readCanonicalInt(pack, 32) != finecosine.length
+        || readCanonicalInt(pack, 36) != tantoangle.length
+        || readCanonicalInt(pack, 40) != CANONICAL_TRANMAP_BYTES) {
+        throw new IllegalArgumentException("canonical table pack header");
+    }
+    canonicalTablePack = pack;
+}
+
+/** Remove the retained pack when its owning MLE session state is released. */
+public static void clearCanonicalTablePack() {
+    canonicalTablePack = null;
+    canonicalTranmap = null;
+}
+
+/** Exact JVM-generated IWAD translucency map; callers must treat it read-only. */
+public static byte[] getCanonicalTranmap() {
+    if (canonicalTranmap == null) {
+        throw new IllegalStateException("canonical TRANMAP is not loaded");
+    }
+    return canonicalTranmap;
+}
+
+private static int readCanonicalInt(byte[] pack, int offset) {
+    return ((pack[offset] & 0xff) << 24)
+        | ((pack[offset + 1] & 0xff) << 16)
+        | ((pack[offset + 2] & 0xff) << 8)
+        | (pack[offset + 3] & 0xff);
+}
+
+private static int decodeCanonicalTable(
+    byte[] pack, int offset, int[] table) {
+    for (int i = 0; i < table.length; i++, offset += 4) {
+        table[i] = readCanonicalInt(pack, offset);
+    }
+    return offset;
+}
+
+private static void loadCanonicalTables() {
+    int offset = CANONICAL_TABLE_PACK_HEADER_BYTES;
+    offset = decodeCanonicalTable(canonicalTablePack, offset, finetangent);
+    offset = decodeCanonicalTable(canonicalTablePack, offset, finesine);
+    offset = decodeCanonicalTable(canonicalTablePack, offset, finecosine);
+    offset = decodeCanonicalTable(canonicalTablePack, offset, tantoangle);
+    canonicalTranmap = new byte[CANONICAL_TRANMAP_BYTES];
+    System.arraycopy(canonicalTablePack, offset, canonicalTranmap, 0,
+        canonicalTranmap.length);
+    offset += canonicalTranmap.length;
+    if (offset != canonicalTablePack.length) {
+        throw new IllegalStateException("canonical table pack payload");
+    }
+}
+
