+            int sourceY, int width, int height,
+            v.renderers.DoomScreen destinationScreen, int destinationX,
+            int destinationY) {
+        Object source = DOOM.graphicSystem.getScreen(sourceScreen);
+        Object destination = DOOM.graphicSystem.getScreen(destinationScreen);
+        int stride = DOOM.graphicSystem.getScreenWidth();
+        for (int row = 0; row < height; ++row) {
+            System.arraycopy(source, (sourceY + row) * stride + sourceX,
+                destination, (destinationY + row) * stride + destinationX,
+                width);
+        }
+    }
