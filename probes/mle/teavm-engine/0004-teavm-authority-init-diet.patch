+    /**
+     * Build only the texture/flat identity needed by gameplay. Patch lookup,
+     * composite columns, sprite definitions, colormaps, screens, and drawing
+     * tables are presentation data and stay out of the retained authority.
+     */
+    @Override
+    public void InitHeadlessDirectories() {
+        try {
+            ByteBuffer[] maptex = new ByteBuffer[texturelumps.length];
+            int[] counts = new int[texturelumps.length];
+            int[] maxoff = new int[texturelumps.length];
+            for (int set = 0; set < texturelumps.length; ++set) {
+                final String lump = texturelumps[set];
+                if (W.CheckNumForName(lump) != -1) {
+                    maptex[set] = W.CacheLumpName(lump, PU_STATIC).getBuffer();
+                    maptex[set].rewind();
+                    maptex[set].order(ByteOrder.LITTLE_ENDIAN);
+                    counts[set] = maptex[set].getInt();
+                    maxoff[set] = W.LumpLength(W.GetNumForName(lump));
+                }
+            }
+            numtextures = counts[TEXTURE1] + counts[TEXTURE2];
+            textures = new texture_t[numtextures];
+            TextureCache = new Hashtable<String, Integer>(numtextures);
+            texturewidthmask = new int[numtextures];
+            textureheight = new int[numtextures];
+            texturetranslation = new int[numtextures];
+
+            int textureSet = TEXTURE1;
+            int directory = 1;
+            final maptexture_t mapped = new maptexture_t();
+            for (int textureNum = 0; textureNum < numtextures;
+                 ++textureNum, ++directory) {
+                if (textureNum == counts[TEXTURE1]) {
+                    textureSet = TEXTURE2;
+                    directory = 1;
+                }
+                final int offset = maptex[textureSet].getInt(directory << 2);
+                if (offset > maxoff[textureSet]) {
+                    I.Error("R_InitTextures: bad texture directory");
+                }
+                maptex[textureSet].position(offset);
+                mapped.unpack(maptex[textureSet]);
+                TextureCache.put(mapped.name.toUpperCase(), textureNum);
+                final texture_t texture = new texture_t();
+                texture.copyFromMapTexture(mapped);
+                textures[textureNum] = texture;
+                int mask = 1;
+                while (mask * 2 <= texture.width) {
+                    mask <<= 1;
+                }
+                texturewidthmask[textureNum] = mask - 1;
+                textureheight[textureNum] = texture.height << FRACBITS;
+                texturetranslation[textureNum] = textureNum;
+            }
+            InitFlats();
+        } catch (IOException exception) {
+            throw new RuntimeException("headless texture directory", exception);
+        }
+    }
+
